{
  "name": "quiet-diary",
  "version": "1.0.0",
  "private": true,
  "description": "Private diary PWA packaged for Android.",
  "scripts": {
    "build:web": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-web.ps1",
    "android:sync": "npm run build:web && cap sync android",
    "android:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4"
  }
}
